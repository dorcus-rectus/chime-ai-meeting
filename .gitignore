# ─── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── ビルド成果物 ───────────────────────────────────────────────────────────────
dist/
build/
out/

# ─── CDK ───────────────────────────────────────────────────────────────────────
cdk/cdk.out/
cdk/cdk-outputs.json
cdk/*.js
!cdk/jest.config.js
!cdk/babel.config.js
cdk/*.d.ts
cdk/lib/*.js
cdk/lib/*.d.ts
cdk/bin/*.js
cdk/bin/*.d.ts
# Lambda は esbuild でバンドルするため TypeScript コンパイル出力を除外
cdk/lambda/**/*.js
cdk/lambda/**/*.d.ts

# ─── フロントエンド ─────────────────────────────────────────────────────────────
frontend/dist/
frontend/.vite/
# tsc が出力する .js / .d.ts は TypeScript ソースと共存させない
frontend/src/**/*.js
frontend/src/**/*.d.ts

# テストレポート・カバレッジ
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/blob-report/

# Playwright テスト結果・一時ファイルは管理対象外
# ※ *.spec.ts-snapshots/ 内のベースライン PNG は管理対象 (除外しない)
frontend/e2e/test-results/**
frontend/src/__tests__/**/*.png

# ─── 環境変数・シークレット ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ─── AWS 認証情報 ───────────────────────────────────────────────────────────────
.aws/
*.pem
*.key

# ─── IDE / エディタ ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── ログ ───────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── 一時ファイル ───────────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
